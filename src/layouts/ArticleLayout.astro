---
export interface Props {
  title: string;
  description: string;
  pubDate: string;
  category: string;
  readingTime: string;
  canonical?: string;
}

const { title, description, pubDate, category, readingTime, canonical } = Astro.props;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": pubDate,
  "dateModified": pubDate,
  "author": {
    "@type": "Organization",
    "name": "AffordableOnlineTherapy Editorial Team",
    "url": "https://affordableonlinetherapy.xyz"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Affordable Online Therapy",
    "url": "https://affordableonlinetherapy.xyz"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonical || Astro.url.href
  }
};

import Layout from './Layout.astro';
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  articleSchema={articleSchema}
>
  <article>
    <!-- Article Header -->
    <header class="article-header">
      <div class="container--wide">
        <div class="article-header__inner">
          <div class="article-header__content">
            <a href={`/category/${category.toLowerCase().replace(/ /g, '-')}`} class="tag">{category}</a>
            <h1>{title}</h1>
            <p class="article-intro">{description}</p>
            <div class="article-meta">
              <span class="reading-time">{readingTime} read</span>
              <span class="article-meta__dot">·</span>
              <time datetime={pubDate}>
                {new Date(pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Article Body -->
    <div class="article-body">
      <div class="container">
        <slot />

        <!-- CTA after content -->
        <div class="cta-box" style="margin-top: 3.5rem;">
          <span class="section-label" style="color: var(--amber);">Ready when you are</span>
          <h2>Talk to a Licensed Therapist</h2>
          <p>Shemesh Wellness connects you with licensed therapists online — affordable, flexible, available. Free initial consultation from $79/session.</p>
          <a href="https://shemeshwellness.com" class="btn" target="_blank" rel="noopener">
            Get Started at ShemeshWellness.com →
          </a>
        </div>

        <!-- Author box -->
        <div class="author-box">
          <div class="author-avatar">AOT</div>
          <div class="author-content">
            <div class="author-name">AffordableOnlineTherapy Editorial Team</div>
            <p class="author-bio">Our content is written to help people understand their mental health options and make informed decisions. All articles are reviewed for accuracy and aligned with current clinical evidence. We are an educational resource, not a therapy provider — for professional support, visit <a href="https://shemeshwellness.com" target="_blank" rel="noopener">ShemeshWellness.com</a>.</p>
          </div>
        </div>
      </div>
    </div>
  </article>

  <style>
    /* ── Article Header ─────────────────────────────────────── */
    .article-header {
      background: var(--near-black);
      padding: 4.5rem 0 4rem;
      border-bottom: 3px solid var(--amber);
      margin-bottom: 0;
      position: relative;
      overflow: hidden;
    }

    .article-header::before {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 1px;
      background: var(--amber);
    }

    .article-header__inner {
      max-width: 820px;
    }

    .article-header h1 {
      color: var(--white);
      font-size: clamp(2.5rem, 6vw, 5rem);
      font-weight: 800;
      line-height: 0.96;
      margin: 1rem 0 1.5rem;
      text-transform: uppercase;
      letter-spacing: -0.01em;
    }

    .article-intro {
      font-size: 1.15rem;
      color: rgba(255,255,255,0.6);
      line-height: 1.7;
      margin-bottom: 1.75rem;
      max-width: 660px;
      font-weight: 400;
      border-left: 3px solid var(--amber);
      padding-left: 1.25rem;
    }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.8rem;
      color: rgba(255,255,255,0.35);
      font-weight: 400;
      letter-spacing: 0.03em;
    }

    .article-meta__dot { color: rgba(255,255,255,0.2); }

    .article-meta time { color: rgba(255,255,255,0.35); }

    /* ── Article Body ───────────────────────────────────────── */
    .article-body {
      padding: 4rem 0 0;
      background: var(--off-white);
    }

    /* Progress line at top of article */
    .article-body .container {
      padding-bottom: 5rem;
    }

    /* ── Author Box ─────────────────────────────────────────── */
    .author-box {
      display: flex;
      gap: 1.5rem;
      align-items: flex-start;
      background: var(--white);
      border: 1px solid var(--border);
      border-left: 3px solid var(--forest);
      padding: 1.75rem;
      margin-top: 2.5rem;
    }

    .author-avatar {
      width: 52px;
      height: 52px;
      min-width: 52px;
      background: var(--forest);
      color: var(--amber);
      border-radius: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 0.65rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .author-name {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--near-black);
      margin-bottom: 0.5rem;
    }

    .author-bio {
      font-size: 0.85rem;
      color: var(--muted);
      margin: 0;
      line-height: 1.65;
    }

    .author-bio a { color: var(--forest-mid); font-weight: 500; }
  </style>
</Layout>
