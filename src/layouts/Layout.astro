---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  articleSchema?: object;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/og-default.png',
  articleSchema,
  noindex = false,
} = Astro.props;

const siteName = 'Affordable Online Therapy';
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Affordable Online Therapy",
  "url": "https://affordableonlinetherapy.xyz",
  "description": "Your guide to accessible, affordable online therapy and mental health support.",
  "sameAs": ["https://shemeshwellness.com"]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteName,
  "url": "https://affordableonlinetherapy.xyz",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://affordableonlinetherapy.xyz/?s={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="google-site-verification" content="xY1kKW5OpUuIWlSuaEeiqQ9rijPIEEGIomuS5J3hTj4" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-RBYE4H13JW"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-RBYE4H13JW');
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: Plus Jakarta Sans (Lyra-style humanist sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400;1,600;1,700&display=swap" rel="stylesheet" />

    <!-- Schema Markup -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {articleSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    )}

    <style is:global>
      /* ── Lyra 2026 Design Tokens ─────────────────────────────── */
      :root {
        --navy:        #002066;
        --cobalt:      #065CE2;
        --blue-vivid:  #0064FB;
        --blue-royal:  #224B90;
        --sky:         #83CFFF;
        --cornflower:  #B2D2FD;
        --ice:         #E8F2FE;
        --white:       #FFFFFF;
        --sun:         #F8B450;
        --sun-bright:  #F89830;
        --dark-text:   #081C45;
        --muted:       #4A5F8A;
        --border:      #C8DEFA;
        --font-body:   'Plus Jakarta Sans', system-ui, sans-serif;
      }

      /* ── Reset ───────────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html {
        font-size: 16px;
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        font-family: var(--font-body);
        background: var(--ice);
        color: var(--dark-text);
        line-height: 1.7;
        font-weight: 400;
      }

      /* ── Typography ──────────────────────────────────────────── */
      h1, h2, h3, h4, h5 {
        font-family: var(--font-body);
        font-weight: 700;
        line-height: 1.1;
        color: var(--navy);
      }

      h1 { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 800; }
      h2 { font-size: clamp(1.75rem, 3.5vw, 2.75rem); margin-top: 3rem; margin-bottom: 1.25rem; }
      h3 { font-size: clamp(1.2rem, 2vw, 1.75rem); margin-top: 2rem; margin-bottom: 0.75rem; }
      h4 { font-size: 1.15rem; margin-top: 1.5rem; margin-bottom: 0.5rem; }

      p { margin-bottom: 1.25rem; color: var(--dark-text); line-height: 1.75; }

      a {
        color: var(--cobalt);
        text-decoration: underline;
        text-decoration-color: var(--cornflower);
        text-underline-offset: 3px;
        transition: color 0.15s, text-decoration-color 0.15s;
      }
      a:hover { color: var(--navy); text-decoration-color: var(--cobalt); }

      img { max-width: 100%; height: auto; }

      strong { color: var(--navy); font-weight: 600; }

      /* ── Layout ──────────────────────────────────────────────── */
      .container      { max-width: 760px;  margin: 0 auto; padding: 0 1.5rem; }
      .container--wide { max-width: 1120px; margin: 0 auto; padding: 0 1.5rem; }

      /* ── Navigation ──────────────────────────────────────────── */
      .nav {
        background: var(--navy);
        padding: 0;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 3px solid var(--cobalt);
      }

      .nav__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }

      .nav__logo {
        font-family: var(--font-body);
        font-weight: 800;
        font-size: 1.25rem;
        text-decoration: none;
        color: var(--white);
        line-height: 1;
        letter-spacing: -0.02em;
      }

      .nav__logo em { color: var(--sky); font-style: normal; }

      .nav__links {
        display: flex;
        align-items: center;
        gap: 2.5rem;
        list-style: none;
      }

      .nav__links a {
        font-size: 0.875rem;
        font-weight: 500;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: color 0.15s;
      }

      .nav__links a:hover { color: var(--white); }

      .nav__cta {
        background: var(--cobalt) !important;
        color: var(--white) !important;
        padding: 0.6rem 1.4rem;
        border-radius: 8px;
        text-decoration: none !important;
        font-size: 0.875rem;
        font-weight: 600;
        transition: background 0.15s, transform 0.15s;
      }

      .nav__cta:hover {
        background: var(--blue-vivid) !important;
        transform: translateY(-1px);
      }

      /* ── Buttons ─────────────────────────────────────────────── */
      .btn {
        display: inline-block;
        background: var(--cobalt);
        color: var(--white) !important;
        padding: 0.875rem 2rem;
        border-radius: 8px;
        font-family: var(--font-body);
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none !important;
        transition: all 0.2s;
        line-height: 1.2;
      }

      .btn:hover {
        background: var(--blue-vivid);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(6, 92, 226, 0.35);
      }

      .btn--outline {
        background: transparent !important;
        color: var(--white) !important;
        border: 2px solid rgba(255,255,255,0.45);
      }

      .btn--outline:hover {
        background: rgba(255,255,255,0.1) !important;
        border-color: var(--white);
        box-shadow: none;
      }

      .btn--ghost {
        background: var(--white) !important;
        color: var(--navy) !important;
        border: 2px solid var(--border);
      }

      .btn--ghost:hover {
        border-color: var(--cobalt);
        color: var(--cobalt) !important;
        box-shadow: none;
      }

      .btn--navy {
        background: var(--navy) !important;
        color: var(--white) !important;
      }

      .btn--navy:hover {
        background: var(--blue-royal) !important;
        box-shadow: 0 8px 24px rgba(0, 32, 102, 0.3);
      }

      /* ── Tags / Badges ───────────────────────────────────────── */
      .tag {
        display: inline-block;
        background: var(--cornflower);
        color: var(--navy);
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        text-decoration: none;
        margin-bottom: 1rem;
      }

      .reading-time { color: var(--muted); font-size: 0.875rem; font-weight: 400; }

      /* ── CTA Box ─────────────────────────────────────────────── */
      .cta-box {
        background: linear-gradient(135deg, var(--navy) 0%, var(--blue-royal) 100%);
        color: var(--white);
        padding: 3.5rem;
        border-radius: 16px;
        text-align: center;
        margin: 3rem 0;
        position: relative;
        overflow: hidden;
      }

      /* sun accent glow */
      .cta-box::after {
        content: '';
        position: absolute;
        top: -40px; right: -40px;
        width: 160px; height: 160px;
        background: radial-gradient(circle, rgba(248,180,80,0.35) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
      }

      .cta-box h2 {
        color: var(--white);
        font-size: clamp(1.75rem, 3.5vw, 2.5rem);
        margin-top: 0;
        margin-bottom: 0.75rem;
      }

      .cta-box p { color: rgba(255,255,255,0.75); margin-bottom: 2rem; font-size: 1.05rem; }

      /* ── Article Styles ──────────────────────────────────────── */
      article h2 {
        font-size: clamp(1.4rem, 2.5vw, 2rem);
        margin-top: 3rem;
        margin-bottom: 1rem;
        color: var(--navy);
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--cornflower);
      }

      article h3 {
        font-size: clamp(1.1rem, 1.8vw, 1.5rem);
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        color: var(--blue-royal);
      }

      article h4 { font-size: 1.05rem; color: var(--cobalt); }

      article ul, article ol { margin: 1rem 0 1.25rem 1.5rem; }
      article li { margin-bottom: 0.6rem; color: var(--dark-text); }

      article blockquote {
        border-left: 4px solid var(--cobalt);
        padding: 1.25rem 1.75rem;
        margin: 2.5rem 0;
        background: var(--ice);
        font-style: italic;
        font-size: 1.05rem;
        color: var(--navy);
        border-radius: 0 8px 8px 0;
      }

      article strong { color: var(--navy); }
      article a { color: var(--cobalt); font-weight: 500; }

      /* ── Footer ──────────────────────────────────────────────── */
      .footer {
        background: var(--navy);
        color: rgba(255,255,255,0.5);
        padding: 5rem 0 3rem;
        margin-top: 8rem;
        font-size: 0.875rem;
      }

      .footer__inner {
        display: grid;
        grid-template-columns: 2.5fr 1fr 1fr;
        gap: 4rem;
        margin-bottom: 4rem;
      }

      .footer__brand {
        font-weight: 800;
        font-size: 1.25rem;
        color: var(--white);
        margin-bottom: 1rem;
        letter-spacing: -0.02em;
      }

      .footer__brand em { color: var(--sky); font-style: normal; }

      .footer__tagline {
        font-size: 0.875rem;
        line-height: 1.7;
        color: rgba(255,255,255,0.45);
        margin-bottom: 0;
        max-width: 340px;
      }

      .footer__heading {
        color: var(--sky);
        font-weight: 700;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 1.25rem;
      }

      .footer__links { list-style: none; }
      .footer__links li { margin-bottom: 0.6rem; }
      .footer__links a { color: rgba(255,255,255,0.45); text-decoration: none; font-size: 0.875rem; transition: color 0.15s; }
      .footer__links a:hover { color: var(--white); }

      .footer__disclaimer {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        padding: 1.25rem 1.5rem;
        border-radius: 8px;
        font-size: 0.8rem;
        line-height: 1.7;
        color: rgba(255,255,255,0.35);
        margin-bottom: 3rem;
      }

      .footer__disclaimer strong { color: rgba(255,255,255,0.5); }

      .footer__bottom {
        padding-top: 2rem;
        border-top: 1px solid rgba(255,255,255,0.08);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.8rem;
        color: rgba(255,255,255,0.3);
      }

      .footer__bottom a { color: var(--sky); text-decoration: none; }
      .footer__bottom a:hover { color: var(--white); }

      /* ── Utilities ───────────────────────────────────────────── */
      .section-label {
        font-weight: 700;
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--cobalt);
        display: block;
        margin-bottom: 0.75rem;
      }

      /* ── Responsive ──────────────────────────────────────────── */
      @media (max-width: 768px) {
        .nav__links { display: none; }
        .footer__inner { grid-template-columns: 1fr; gap: 2.5rem; }
        .footer__bottom { flex-direction: column; gap: 0.75rem; text-align: center; }
        .cta-box { padding: 2.5rem 1.5rem; }
        h2 { margin-top: 2rem; }
      }
    </style>
  </head>

  <body>
    <nav class="nav">
      <div class="container--wide">
        <div class="nav__inner">
          <a href="/" class="nav__logo">Affordable<em>Therapy</em></a>
          <ul class="nav__links">
            <li><a href="/articles/what-is-online-therapy">What is Therapy?</a></li>
            <li><a href="/articles/how-to-find-affordable-therapy">Find a Therapist</a></li>
            <li><a href="/articles/types-of-therapy-explained">Types of Therapy</a></li>
          </ul>
          <a href="https://shemeshwellness.com" class="nav__cta" target="_blank" rel="noopener">Start Therapy →</a>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="footer">
      <div class="container--wide">
        <div class="footer__inner">
          <div>
            <div class="footer__brand">Affordable<em>Therapy</em>.xyz</div>
            <p class="footer__tagline">A free resource helping people understand therapy, find the right fit, and take the first step toward mental wellness — without the confusion or cost barrier.</p>
          </div>
          <div>
            <div class="footer__heading">Resources</div>
            <ul class="footer__links">
              <li><a href="/articles/what-is-online-therapy">What is Online Therapy?</a></li>
              <li><a href="/articles/types-of-therapy-explained">Types of Therapy</a></li>
              <li><a href="/articles/how-to-find-affordable-therapy">Find Affordable Therapy</a></li>
              <li><a href="/articles/how-to-start-therapy">How to Start Therapy</a></li>
              <li><a href="/articles/signs-you-need-therapy">Signs You Need Therapy</a></li>
            </ul>
          </div>
          <div>
            <div class="footer__heading">Get Help Now</div>
            <ul class="footer__links">
              <li><a href="https://shemeshwellness.com" target="_blank" rel="noopener">Book a Session</a></li>
              <li><a href="https://shemeshwellness.com" target="_blank" rel="noopener">Meet Our Therapists</a></li>
              <li><a href="/articles/online-therapy-for-anxiety">Anxiety Support</a></li>
              <li><a href="/articles/online-therapy-for-depression">Depression Support</a></li>
              <li><a href="/articles/online-therapy-for-burnout">Burnout Recovery</a></li>
            </ul>
          </div>
        </div>

        <div class="footer__disclaimer">
          <strong>Crisis Resources:</strong> If you're in immediate distress, contact the 988 Suicide &amp; Crisis Lifeline (call or text 988 in the US), Crisis Text Line (text HOME to 741741), or your local emergency services. This website provides educational information only and is not a substitute for professional mental health care.
        </div>

        <div class="footer__bottom">
          <span>© 2025 AffordableOnlineTherapy.xyz — Educational resource</span>
          <span>Professional therapy at <a href="https://shemeshwellness.com" target="_blank" rel="noopener">ShemeshWellness.com</a></span>
        </div>
      </div>
    </footer>
  </body>
</html>
