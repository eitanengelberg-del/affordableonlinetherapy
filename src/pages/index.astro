---
import Layout from '../layouts/Layout.astro';

const heroSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does online therapy cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Online therapy typically costs between $60–$150 per session, which is often less than traditional in-person therapy. Many platforms offer sliding scale fees or subscription plans starting around $60/week."
      }
    },
    {
      "@type": "Question",
      "name": "Is online therapy as effective as in-person therapy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Multiple studies show online therapy is equally effective as in-person therapy for most mental health conditions including anxiety, depression, and stress. The APA recognizes telehealth as a valid, evidence-based treatment modality."
      }
    },
    {
      "@type": "Question",
      "name": "How do I find an affordable therapist online?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can find affordable online therapy through platforms like Shemesh Wellness, which offer flexible pricing and licensed therapists. Many services offer free consultations so you can find the right fit before committing."
      }
    }
  ]
};
---

<Layout
  title="Affordable Online Therapy — Find Help That Fits Your Life & Budget"
  description="Your guide to accessible, affordable online therapy. Learn what therapy costs, how it works, and how to find the right therapist online — without breaking the bank."
  articleSchema={heroSchema}
>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__badge">Free Mental Health Resource</div>
      <h1>Therapy Shouldn't Be Out of Reach</h1>
      <p class="hero__sub">We help you understand your options, cut through the confusion, and find affordable online therapy that actually works.</p>
      <div class="hero__actions">
        <a href="https://shemeshwellness.com" class="btn btn--primary" target="_blank" rel="noopener">Find a Therapist Now →</a>
        <a href="/articles/what-is-online-therapy" class="btn btn--ghost">Learn How It Works</a>
      </div>
      <p class="hero__trust">Trusted resource for 10,000+ people finding therapy each month</p>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="trust-bar">
    <div class="container--wide">
      <div class="trust-bar__inner">
        <div class="trust-item">
          <span class="trust-item__icon">🧠</span>
          <span>Evidence-based information</span>
        </div>
        <div class="trust-item">
          <span class="trust-item__icon">🔒</span>
          <span>No data sold, ever</span>
        </div>
        <div class="trust-item">
          <span class="trust-item__icon">💬</span>
          <span>Written by mental health researchers</span>
        </div>
        <div class="trust-item">
          <span class="trust-item__icon">✓</span>
          <span>Free to read, always</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Topic clusters -->
  <section class="topics">
    <div class="container--wide">
      <h2 class="section-title">Start Here</h2>
      <p class="section-sub">Choose what's most relevant to you right now</p>

      <div class="topic-grid">
        <a href="/articles/what-is-online-therapy" class="topic-card topic-card--featured">
          <div class="topic-card__icon">🌐</div>
          <h3>What is Online Therapy?</h3>
          <p>How video and text therapy works, what to expect, and whether it's right for you.</p>
          <span class="topic-card__link">Read the guide →</span>
        </a>

        <a href="/articles/how-to-find-affordable-therapy" class="topic-card">
          <div class="topic-card__icon">💰</div>
          <h3>How to Find Affordable Therapy</h3>
          <p>Real strategies for getting therapy that fits your budget — with or without insurance.</p>
          <span class="topic-card__link">Read the guide →</span>
        </a>

        <a href="/articles/types-of-therapy-explained" class="topic-card">
          <div class="topic-card__icon">📋</div>
          <h3>Types of Therapy Explained</h3>
          <p>CBT, DBT, psychodynamic, EMDR — what they are and which one might suit you.</p>
          <span class="topic-card__link">Read the guide →</span>
        </a>

        <a href="/articles/online-therapy-for-anxiety" class="topic-card">
          <div class="topic-card__icon">😰</div>
          <h3>Therapy for Anxiety</h3>
          <p>How online therapy treats anxiety disorders, panic attacks, and social anxiety.</p>
          <span class="topic-card__link">Read the guide →</span>
        </a>

        <a href="/articles/online-therapy-for-depression" class="topic-card">
          <div class="topic-card__icon">🌧️</div>
          <h3>Therapy for Depression</h3>
          <p>Understanding depression treatment online and how to find the right support.</p>
          <span class="topic-card__link">Read the guide →</span>
        </a>

        <a href="/articles/how-to-start-therapy" class="topic-card">
          <div class="topic-card__icon">🚀</div>
          <h3>How to Start Therapy</h3>
          <p>A step-by-step guide to booking your first session and knowing what to expect.</p>
          <span class="topic-card__link">Read the guide →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section (boosts featured snippets) -->
  <section class="faq">
    <div class="container">
      <h2>Common Questions About Online Therapy</h2>

      <div class="faq-list">
        <details class="faq-item">
          <summary>How much does online therapy cost?</summary>
          <p>Online therapy typically costs between <strong>$60–$150 per session</strong>. Many platforms offer weekly subscription plans. Sliding scale fees are also common for those who qualify. Compared to traditional in-person therapy ($150–$300/session), online is significantly more affordable.</p>
        </details>

        <details class="faq-item">
          <summary>Is online therapy as effective as in-person therapy?</summary>
          <p>Yes. <strong>Multiple peer-reviewed studies</strong> — including research published in the Journal of Psychological Disorders — confirm that online therapy produces equivalent outcomes to in-person therapy for conditions like anxiety, depression, PTSD, and stress.</p>
        </details>

        <details class="faq-item">
          <summary>Do I need a diagnosis to start therapy?</summary>
          <p>No. You don't need a diagnosis to begin therapy. Many people start therapy to manage stress, improve relationships, work through life transitions, or simply have a consistent space to process their thoughts. A therapist will assess your needs in your first session.</p>
        </details>

        <details class="faq-item">
          <summary>What's the difference between a therapist, psychologist, and psychiatrist?</summary>
          <p>A <strong>therapist</strong> (counselor/LCSW) provides talk therapy. A <strong>psychologist</strong> holds a doctoral degree and can conduct psychological testing. A <strong>psychiatrist</strong> is a medical doctor who can prescribe medication. Most people start with a therapist.</p>
        </details>

        <details class="faq-item">
          <summary>How do I know if a therapist is right for me?</summary>
          <p>The therapeutic relationship is the single biggest predictor of success. Most good therapists offer a free or discounted first session. It's completely normal to try 2–3 therapists before finding the right fit. <a href="https://shemeshwellness.com" target="_blank" rel="noopener">Shemesh Wellness</a> helps match you with the right therapist from the start.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Shemesh CTA -->
  <section style="padding: 2rem 0 4rem;">
    <div class="container">
      <div class="cta-box">
        <h2>Ready to Take the First Step?</h2>
        <p>Shemesh Wellness offers affordable, flexible online therapy with licensed professionals. Start with a free consultation — no commitment required.</p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a href="https://shemeshwellness.com" class="btn" target="_blank" rel="noopener">Book a Free Consultation →</a>
          <a href="/articles/what-is-online-therapy" class="btn btn--outline">Learn More First</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    padding: 6rem 0 5rem;
    background: linear-gradient(180deg, var(--cream) 0%, var(--warm-white) 100%);
    text-align: center;
    border-bottom: 1px solid var(--light-grey);
  }

  .hero__badge {
    display: inline-block;
    background: var(--accent-light);
    color: var(--accent);
    padding: 0.35rem 1rem;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    margin-bottom: 1.25rem;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero__sub {
    font-size: 1.2rem;
    color: #4B5563;
    max-width: 520px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .btn--primary {
    background: var(--sage);
    color: white;
    padding: 0.875rem 2rem;
    border-radius: 100px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn--primary:hover { background: var(--sage-dark); color: white; transform: translateY(-1px); }

  .btn--ghost {
    background: transparent;
    color: var(--charcoal);
    padding: 0.875rem 2rem;
    border-radius: 100px;
    font-weight: 500;
    text-decoration: none;
    border: 1.5px solid var(--light-grey);
    transition: all 0.2s;
    display: inline-block;
  }

  .btn--ghost:hover { border-color: var(--sage); color: var(--sage-dark); }

  .hero__trust {
    font-size: 0.8rem;
    color: var(--mid-grey);
    margin: 0;
  }

  /* Trust bar */
  .trust-bar {
    background: var(--charcoal);
    padding: 1.25rem 0;
  }

  .trust-bar__inner {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #D1D5DB;
    font-size: 0.875rem;
  }

  /* Topics */
  .topics { padding: 5rem 0; }

  .section-title {
    text-align: center;
    margin-bottom: 0.5rem;
    margin-top: 0;
  }

  .section-sub {
    text-align: center;
    color: var(--mid-grey);
    margin-bottom: 3rem;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .topic-card {
    background: var(--cream);
    border: 1px solid var(--light-grey);
    border-radius: 12px;
    padding: 1.75rem;
    text-decoration: none;
    color: var(--charcoal);
    transition: all 0.2s;
    display: block;
  }

  .topic-card:hover {
    border-color: var(--sage-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(123, 158, 135, 0.12);
    color: var(--charcoal);
  }

  .topic-card--featured {
    grid-column: span 1;
    background: linear-gradient(135deg, var(--sage) 0%, var(--sage-dark) 100%);
    border-color: transparent;
    color: white;
  }

  .topic-card--featured h3,
  .topic-card--featured p { color: rgba(255,255,255,0.9); }

  .topic-card--featured .topic-card__link { color: rgba(255,255,255,0.7); }

  .topic-card__icon { font-size: 2rem; margin-bottom: 1rem; }

  .topic-card h3 { font-size: 1.1rem; margin: 0 0 0.5rem; }
  .topic-card p { font-size: 0.9rem; line-height: 1.6; margin-bottom: 1rem; }

  .topic-card__link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--sage-dark);
  }

  /* FAQ */
  .faq { padding: 5rem 0; background: var(--cream); }
  .faq h2 { margin-top: 0; margin-bottom: 2rem; }

  .faq-item {
    border: 1px solid var(--light-grey);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    background: white;
    overflow: hidden;
  }

  .faq-item summary {
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-weight: 500;
    font-size: 1rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--charcoal);
  }

  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 1.25rem; color: var(--sage); }
  .faq-item[open] summary::after { content: '−'; }

  .faq-item p {
    padding: 0 1.5rem 1.25rem;
    font-size: 0.95rem;
    color: #374151;
    border-top: 1px solid var(--light-grey);
    padding-top: 1rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .topic-grid { grid-template-columns: 1fr; }
    .trust-bar__inner { gap: 1.5rem; }
  }
</style>
