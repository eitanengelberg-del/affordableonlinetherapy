<style>
  /* ── Hero ──────────────────────────────────────────────────── */
  .hero {
    background: var(--white);
    padding: 6rem 0 5rem;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  /* soft sky gradient bloom top-right */
  .hero::after {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 480px; height: 480px;
    background: radial-gradient(circle, rgba(131,207,255,0.25) 0%, transparent 65%);
    pointer-events: none;
    border-radius: 50%;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero__eyebrow {
    display: inline-block;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cobalt);
    margin-bottom: 1.25rem;
  }

  .hero__headline {
    font-size: clamp(3rem, 6.5vw, 5.5rem);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--navy);
    margin-bottom: 1.75rem;
  }

  .hero__headline em {
    color: var(--cobalt);
    font-style: normal;
  }

  .hero__sub {
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 480px;
    line-height: 1.75;
    margin-bottom: 2.5rem;
    font-weight: 400;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .hero__trust {
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0;
    font-weight: 400;
  }

  /* Stats panel */
  .hero__stats {
    background: linear-gradient(160deg, var(--navy) 0%, var(--blue-royal) 100%);
    border-radius: 16px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    overflow: hidden;
  }

  /* sun glow */
  .hero__stats::after {
    content: '';
    position: absolute;
    bottom: -30px; right: -30px;
    width: 120px; height: 120px;
    background: radial-gradient(circle, rgba(248,180,80,0.4) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .stat {
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    position: relative;
    z-index: 1;
  }

  .stat:last-child { border-bottom: none; padding-bottom: 0; }
  .stat:first-child { padding-top: 0; }

  .stat__num {
    display: block;
    font-size: 2.75rem;
    font-weight: 800;
    color: var(--sky);
    line-height: 1;
    margin-bottom: 0.25rem;
    letter-spacing: -0.02em;
  }

  .stat__label {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
    font-weight: 400;
  }

  .stat--cta { padding-top: 1.75rem; }

  .stat__link {
    display: inline-block;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--sun) !important;
    text-decoration: none !important;
    transition: color 0.15s;
  }

  .stat__link:hover { color: var(--white) !important; }

  /* ── Trust Bar ─────────────────────────────────────────────── */
